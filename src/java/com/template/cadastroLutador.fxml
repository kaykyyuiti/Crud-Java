<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="650.0" prefWidth="850.0" style="-fx-background-color: #2F2F2F;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.MainController">

    <children>

        <Label layoutX="297.0" layoutY="14.0" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Campeões Brasileiros" textFill="GOLD" />

        <Label layoutX="28.0" layoutY="59.0" text="ID:" textFill="WHITE" />
        <TextField fx:id="txtId" editable="false" layoutX="118.0" layoutY="54.0" prefWidth="80.0" />

        <Label layoutX="28.0" layoutY="99.0" text="Nome:" textFill="WHITE" />
        <TextField fx:id="txtNome" layoutX="118.0" layoutY="94.0" prefWidth="250.0" />

        <Label layoutX="28.0" layoutY="139.0" text="Idade:" textFill="WHITE" />
        <TextField fx:id="txtIdade" layoutX="118.0" layoutY="134.0" prefWidth="100.0" />

        <Label layoutX="428.0" layoutY="59.0" text="Categoria:" textFill="WHITE" />
        <ComboBox fx:id="cbCategoria" layoutX="528.0" layoutY="54.0" prefWidth="200.0" />

        <Label layoutX="428.0" layoutY="99.0" text="Gênero:" textFill="WHITE" />
        <ComboBox fx:id="cbGenero" layoutX="528.0" layoutY="94.0" prefWidth="200.0" />

        <Label layoutX="428.0" layoutY="139.0" text="Sequência:" textFill="WHITE" />
        <TextField fx:id="txtSequencia" layoutX="528.0" layoutY="134.0" prefWidth="100.0" />

        <Label layoutX="30.0" layoutY="205.0" text="Pesquisar por nome:" textFill="WHITE" />
        <TextField fx:id="txtPesquisar" layoutX="141.0" layoutY="201.0" prefWidth="250.0" />

        <Button layoutX="407.0" layoutY="201.0" onAction="#btnPesquisarAction" text="Pesquisar" />

        <Button fx:id="btnAdicionar" layoutX="36.0" layoutY="255.0" onAction="#btnAdicionarAction" prefWidth="120.0" style="-fx-background-color: #32CD32;" text="Adicionar" textFill="WHITE" />

        <Button fx:id="btnAtualizar" layoutX="176.0" layoutY="255.0" onAction="#btnAtualizarAction" prefWidth="120.0" style="-fx-background-color: #FFD700;" text="Atualizar" textFill="WHITE" />

        <Button fx:id="btnExcluir" layoutX="316.0" layoutY="255.0" onAction="#btnExcluirAction" prefWidth="120.0" style="-fx-background-color: #B22222;" text="Excluir" textFill="WHITE" />

        <Button fx:id="btnLimpar" layoutX="458.0" layoutY="255.0" onAction="#btnLimparAction" prefWidth="120.0" style="-fx-background-color: #B22222;" text="Limpar" textFill="WHITE" />

        <TableView fx:id="tblLutador" layoutX="30.0" layoutY="316.0" onMouseClicked="#carregarCampos" prefHeight="250.0" prefWidth="644.0" style="-fx-background-color: white;">

            <columns>

                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="colNome" prefWidth="180.0" text="Nome" />
                <TableColumn fx:id="colCategoria" prefWidth="150.0" text="Categoria" />
                <TableColumn fx:id="colGenero" prefWidth="120.0" text="Gênero" />
                <TableColumn fx:id="colIdade" prefWidth="50.0" text="Idade" />
                <TableColumn fx:id="colSequencia" prefWidth="86.0" text="Sequência" />

            </columns>
        </TableView>

        <Label fx:id="lblMensagem" layoutX="30.0" layoutY="590.0" textFill="WHITE" />
        <Label fx:id="lblTotal" layoutX="600.0" layoutY="590.0" textFill="WHITE" />

    </children>
</AnchorPane>
